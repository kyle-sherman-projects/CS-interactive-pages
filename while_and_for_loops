<script>
function toggleReveal(btn){const c=btn.nextElementSibling;c.classList.toggle('visible');if(!btn.dataset.o)btn.dataset.o=btn.textContent;btn.textContent=c.classList.contains('visible')?'Hide / Ocultar':btn.dataset.o}
function selectChoice(el,cls){el.parentElement.querySelectorAll('.choice-btn').forEach(b=>{b.className='choice-btn'});el.classList.add(cls)}
const sections=document.querySelectorAll('section[data-section]'),steps=document.querySelectorAll('.progress-bar .step');let mx=0;
const obs=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){const i=parseInt(e.target.dataset.section)-1;if(i>mx)mx=i;steps.forEach((s,j)=>{s.className='step';if(j<mx)s.classList.add('done');else if(j===mx)s.classList.add('active')})}})},{threshold:.3});
sections.forEach(s=>obs.observe(s));
